---
import MainLayout from '../layouts/MainLayout.astro';
import AppStoreButton from '../components/AppStoreButton.astro';
---

<MainLayout title="Tickle — Count what matters. Build better habits.">
  <section class="hero container">
    <div class="hero-content animate-up">
      <h1 class="hero-title">
        Count what matters.<br />
        <span class="hero-accent">Build better habits.</span>
      </h1>
      <p class="hero-subtitle">
        Track your daily goals, build consistency, and see your progress grow.
      </p>
      <AppStoreButton />
    </div>
    <div class="hero-visual animate-up delay-1">
      <img
        src="/mockups/hero-mockup.png"
        alt="Tickle app showing daily habit counters"
        class="hero-mockup-img float"
        width="320"
        height="640"
      />
    </div>
  </section>

  <section id="features" class="features container">
    <div class="section-heading reveal">
      <h2>Designed for Speed & Calm</h2>
      <p>No clutter, no noise. Just tactile and instantaneous counting.</p>
    </div>

    <div class="feature-grid">
      <div class="feature-card reveal">
        <div class="feature-img-wrapper">
          <img src="/mockups/Frame-3.jpg" alt="Counter Setup" class="mockup-img-sm" />
        </div>
        <div class="feature-text">
          <h3>Instant Tracking</h3>
          <p>Open the app, tap once, and close it. All within seconds.</p>
        </div>
      </div>

      <div class="feature-card reveal delay-1">
        <div class="feature-img-wrapper">
          <img src="/mockups/Frame-4.jpg" alt="Counter Insights" class="mockup-img-sm" />
        </div>
        <div class="feature-text">
          <h3>Beautiful Insights</h3>
          <p>View daily totals, streaks, and peak days with gorgeous visual heatmaps.</p>
        </div>
      </div>

      <div class="feature-card reveal delay-2">
        <div class="feature-img-wrapper">
          <img src="/mockups/Frame-5.jpg" alt="History" class="mockup-img-sm" />
        </div>
        <div class="feature-text">
          <h3>Tactile Feedback</h3>
          <p>Interactions feel satisfying through perfectly tuned animation and haptics.</p>
        </div>
      </div>
      
      <div class="feature-card reveal delay-3">
        <div class="feature-img-wrapper">
          <img src="/mockups/Frame-6.jpg" alt="Settings" class="mockup-img-sm" />
        </div>
        <div class="feature-text">
          <h3>Organize Anything</h3>
          <p>Group counters by color and emoji for a breathable, lightweight experience.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta container reveal">
    <div class="cta-box">
      <h2>Ready to start counting?</h2>
      <p>Download Tickle today and experience the simplest way to track your habits.</p>
      <AppStoreButton variant="light" />
    </div>
  </section>

  <script>
    // Scroll reveal animation
    const revealElements = document.querySelectorAll('.reveal');
    
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
          revealObserver.unobserve(entry.target);
        }
      });
    }, {
      rootMargin: '0px 0px -50px 0px',
      threshold: 0.1
    });

    revealElements.forEach(el => revealObserver.observe(el));
  </script>

  <style>
    /* Hero Section */
    .hero {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 48px;
      padding: 64px 24px 96px;
    }

    .hero-content {
      flex: 1;
      max-width: 520px;
    }

    .hero-title {
      font-size: clamp(2.25rem, 4.5vw, 3.75rem);
      font-weight: 800;
      letter-spacing: -0.04em;
      line-height: 1.08;
      margin-bottom: 20px;
    }

    .hero-accent {
      color: #7b5ea7;
    }

    .hero-subtitle {
      font-size: 1.125rem;
      color: var(--text-secondary);
      margin-bottom: 32px;
      max-width: 420px;
      line-height: 1.6;
    }

    .hero-visual {
      flex-shrink: 0;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .hero-visual::before {
      content: '';
      position: absolute;
      width: 280px;
      height: 280px;
      background: radial-gradient(circle, rgba(123, 94, 167, 0.15) 0%, transparent 70%);
      z-index: -1;
    }

    .hero-mockup-img {
      display: block;
      width: 240px;
      height: auto;
      border-radius: 24px;
      box-shadow: var(--shadow-lg);
    }

    .float {
      animation: float 6s ease-in-out infinite;
      animation-delay: 0.8s;
    }

    /* Initial Load Animations */
    .animate-up {
      animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      opacity: 0;
    }
    
    .delay-1 { animation-delay: 0.1s; }
    .delay-2 { animation-delay: 0.2s; }
    .delay-3 { animation-delay: 0.3s; }

    /* Features Section */
    .features {
      padding: 120px 24px;
    }
    
    .section-heading {
      text-align: center;
      margin-bottom: 80px;
      max-width: 600px;
      margin-left: auto;
      margin-right: auto;
    }
    
    .section-heading h2 {
      font-size: 3rem;
      font-weight: 700;
      letter-spacing: -1px;
      margin-bottom: 16px;
    }
    
    .section-heading p {
      font-size: 1.25rem;
      color: var(--text-secondary);
    }
    
    .feature-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 32px;
    }
    
    .feature-card {
      background: var(--card-bg);
      border-radius: var(--border-radius);
      padding: 32px;
      text-align: center;
      box-shadow: var(--shadow-sm);
      transition: all var(--transition-smooth);
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    
    .feature-card:hover {
      transform: translateY(-8px);
      box-shadow: var(--shadow-md);
    }
    
    .feature-img-wrapper {
      margin-bottom: 32px;
      height: 380px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    
    .mockup-img-sm {
      max-height: 100%;
      border-radius: 24px;
      box-shadow: 0 8px 24px rgba(0,0,0,0.1);
      border: 4px solid #f0f0f0;
      transition: transform var(--transition-smooth);
    }
    
    .feature-card:hover .mockup-img-sm {
      transform: scale(1.03);
    }
    
    .feature-text h3 {
      font-size: 1.5rem;
      margin-bottom: 12px;
    }
    
    .feature-text p {
      color: var(--text-secondary);
      font-size: 1rem;
    }

    /* CTA Section */
    .cta {
      padding: 80px 24px 120px;
    }
    
    .cta-box {
      background: linear-gradient(135deg, #1a1a2e 0%, #2d2d44 100%);
      border-radius: 32px;
      padding: 64px 32px;
      text-align: center;
      color: #fff;
      box-shadow: var(--shadow-lg);
    }
    
    .cta-box h2 {
      font-size: 2.5rem;
      margin-bottom: 16px;
    }
    
    .cta-box p {
      font-size: 1.25rem;
      opacity: 0.8;
      margin-bottom: 40px;
    }

    /* Responsive Design */
    @media (max-width: 900px) {
      .hero {
        flex-direction: column;
        text-align: center;
        padding: 40px 24px 72px;
        gap: 40px;
      }

      .hero-subtitle {
        margin-left: auto;
        margin-right: auto;
      }

      .hero-mockup-img {
        width: 200px;
      }
    }

    @media (max-width: 768px) {
      .section-heading h2 {
        font-size: 2rem;
      }
      
      .feature-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</MainLayout>
